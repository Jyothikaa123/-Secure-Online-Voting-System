# VOTER LOGIN
@app.route("/voter_login", methods=["GET", "POST"])
def voter_login():
    if request.method == "POST":
        data = load_data()
        phone = request.form["phone"]
        password = request.form["password"]

        for voter in data["voters"]:
            if voter["phone"] == phone and voter["password"] == password:
                session["voter_phone"] = voter["phone"]  # <- track voter
                return redirect("/enter_election")

        return "❌ Invalid Voter Login"

    return render_template("voter_login.html")

@app.route("/vote/<candidate_phone>/<election_id>")
def vote(candidate_phone, election_id):
    if "voter_phone" not in session:
        return redirect("/voter_login")

    data = load_data()
    voter_phone = session["voter_phone"]

    # Prevent double voting
    for v in data["votes"]:
        if v["voter_phone"] == voter_phone and v["election_id"] == election_id:
            return "❌ You have already voted in this election!"

    # Save the vote
    vote_record = {
        "voter_phone": voter_phone,
        "candidate_phone": candidate_phone,
        "election_id": election_id
    }

    data["votes"].append(vote_record)
    save_data(data)

    return "✅ Your vote has been cast successfully!"
