# =====================================
# admin Dashboard
# =====================================
@app.route("/admin_dashboard")
def admin_dashboard():

    if "admin_phone" not in session:
        return redirect("/admin_login")

    data = load_data()

    elections = data["elections"]
    candidates = data["candidates"]
    votes = data["votes"]

    results = {}
    election_candidates = {}

    for election in elections:

        eid = election["election_id"]

        results[eid] = {}
        election_candidates[eid] = []

        # all candidates (you can filter later if needed)
        for c in candidates:
            election_candidates[eid].append(c)
            results[eid][c["name"]] = 0

        # count votes
        for v in votes:
            if v["election_id"] == eid:
                for c in candidates:
                    if c["phone"] == v["candidate_phone"]:
                        results[eid][c["name"]] += 1

    return render_template(
        "admin_dashboard.html",
        elections=elections,
        results=results,
        election_candidates=election_candidates
    )
