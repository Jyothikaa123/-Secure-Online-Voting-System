# =====================================
# ENTER ELECTION (VOTER FILTER PAGE)
# =====================================
@app.route("/enter_election", methods=["GET","POST"])
def enter_election():

    if request.method == "POST":

        data = load_data()

        election_name = request.form["election_name"]
        election_id = request.form["election_id"]

        matched = []

        for e in data["elections"]:
            if (
                e["election_name"] == election_name and
                e["election_id"] == election_id
            ):
                matched.append(e)

        session["selected_elections"] = matched
        session["selected_name"] = election_name
        session["selected_id"] = election_id

        return redirect("/voter_dashboard")

    return render_template("enelection.html")   
# =====================================
# Voter  Dashboard
# ===================================== 

@app.route("/voter_dashboard")
def voter_dashboard():

    if "selected_elections" not in session:
        return redirect("/enter_election")

    data = load_data()

    candidates = data["candidates"]
    votes = data["votes"]

    selected = session["selected_elections"]

    now = datetime.now()

    available = []
    held = []
    results = {}

    for index, e in enumerate(selected):

        try:
            start = datetime.fromisoformat(e["start_time"])
            end = datetime.fromisoformat(e["end_time"])
        except:
              continue

        unique_key = f"{e['election_id']}_{index}"

        if start <= now <= end:
           available.append(e)

        elif now > end:
             held.append(e)

        results[unique_key] = {}

        for c in candidates:
            results[unique_key][c["name"]] = 0

        for v in votes:
            if v["election_id"] == e["election_id"]:
                for c in candidates:
                    if c["phone"] == v["candidate_phone"]:
                        results[unique_key][c["name"]] += 1

    return render_template(
        "voter_dashboard.html",
        available=available,
        held=held,
        results=results,
        candidates=candidates
    )

# =====================================
# Candidate Enroll in Election
# =====================================
@app.route("/candidate_enroll", methods=["POST"])
def candidate_enroll():

    if "candidate_phone" not in session:
        return redirect("/user_login")

    data = load_data()

    election_name = request.form["election_name"]
    election_id = request.form["election_id"]

    candidate_phone = session["candidate_phone"]

    # check election validity
    valid = False
    for e in data["elections"]:
        if e["type"] == election_name and e["election_id"] == election_id:
            valid = True
            break

    if not valid:
        return "❌ Invalid Election Name or ID"

    # prevent duplicate enrollment
    for enr in data["candidate_enrollments"]:
        if (
            enr["candidate_phone"] == candidate_phone and
            enr["election_id"] == election_id
        ):
            return redirect("/user_dashboard")

    enrollment = {
        "candidate_phone": candidate_phone,
        "election_name": election_name,
        "election_id": election_id
    }

    data["candidate_enrollments"].append(enrollment)
    save_data(data)

    return redirect("/user_dashboard")        
# =====================================
# Candidate Dashboard
# =====================================    
@app.route("/user_dashboard")
def user_dashboard():

    if "candidate_phone" not in session:
        return redirect("/user_login")

    data = load_data()

    candidate_phone = session["candidate_phone"]

    enrollments = data.get("candidate_enrollments", [])
    elections = data["elections"]
    votes = data["votes"]

    participated = []
    results = {}

    # find enrolled elections
    for enr in enrollments:
        if enr["candidate_phone"] == candidate_phone:

            for e in elections:
                if e["election_id"] == enr["election_id"]:
                    participated.append(e)

                    # count votes
                    count = 0
                    for v in votes:
                        if (
                            v["candidate_phone"] == candidate_phone
                            and v["election_id"] == e["election_id"]
                        ):
                            count += 1

                    results[e["election_id"]] = count

    return render_template(
        "user_dashboard.html",
        elections=participated,
        results=results
    )
